]
);
}

function saveGame(){
if(!S){
alert("请先开始游戏");
return;
}
localStorage.setItem("riize_idol_sister_save", JSON.stringify(S));
el("status").textContent = "已保存";
}

function loadGame(){
var s = localStorage.getItem("riize_idol_sister_save");
if(!s){
alert("没有浏览器存档");
return;
}
S = JSON.parse(s);
hideAll();
el("game").classList.remove("hidden");
el("bottom").classList.remove("hidden");
render();
}

function exportSave(){
if(!S){
alert("请先开始游戏");
return;
}
var code = btoa(unescape(encodeURIComponent(JSON.stringify(S))));
el("saveBox").value = code;
el("saveBox").focus();
el("saveBox").select();
alert("存档码已生成，请复制到备忘录。");
}

function importSave(){
var code = el("saveBox").value.trim();
if(!code){
alert("请先粘贴存档码");
return;
}
try{
S = JSON.parse(decodeURIComponent(escape(atob(code))));
localStorage.setItem("riize_idol_sister_save", JSON.stringify(S));
hideAll();
el("game").classList.remove("hidden");
el("bottom").classList.remove("hidden");
render();
}catch(e){
alert("存档码无效或复制不完整");
}
}
