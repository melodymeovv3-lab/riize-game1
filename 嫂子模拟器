function nextWeek(){
S.week++;

if(S.week >= 36 || S.favor >= 91){
ending();
return;
}

var r = Math.random();

if(S.secrecy < 30){
mediaCrisis();
return;
}
if(S.company > 80){
companyForce();
return;
}
if(S.career > 90){
careerCrash();
return;
}
if(S.mood < 20){
emotionCrash();
return;
}

if(r < 0.25) dailyEvent();
else if(r < 0.5) workEvent();
else if(r < 0.75) fandomEvent();
else companyEvent();
}

