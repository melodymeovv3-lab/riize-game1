result = "HE：隐秘而稳定的爱";
}else if(S.secrecy < 20 && S.company > 85){
result = "BE：曝光后的分离";
}else if(S.mood < 25){
result = "BE：你选择离开";
}else if(S.youth >= 80){
result = "GE：各自发光";
}else if(S.favor >= 95 && S.popularity >= 50 && S.company <= 70){
result = "SE：公开恋爱";
